{
  "name": "multi-ai-translator",
  "version": "0.1.2",
  "description": "Browser extension for translating web pages using multiple AI providers",
  "type": "module",
  "scripts": {
    "sync:version": "node scripts/sync-manifest-version.js",
    "sync:version:chrome": "node scripts/sync-manifest-version.js chrome",
    "sync:version:firefox": "node scripts/sync-manifest-version.js firefox",
    "dev": "vite build --config vite.config.ts --watch",
    "dev:firefox": "vite build --config vite.firefox.config.ts --watch",
    "build": "yarn build:chrome && yarn build:firefox",
    "build:chrome": "yarn sync:version:chrome && vite build --config vite.config.ts",
    "build:firefox": "yarn sync:version:firefox && vite build --config vite.firefox.config.ts",
    "clean": "gulp clean",
    "lint": "gulp lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json}\"",
    "package": "node scripts/package.js",
    "release": "yarn clean && yarn format && yarn lint && yarn build && yarn package"
  },
  "keywords": [
    "chrome-extension",
    "edge-extension",
    "firefox-addon",
    "translation",
    "ai",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@prantlf/gulp-jsonlint": "^3.0.1",
    "@types/chrome": "^0.1.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^7.0.1",
    "cross-env": "^10.1.0",
    "del": "^8.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "gulp": "^5.0.1",
    "gulp-eslint-new": "^2.6.2",
    "gulp-stylelint-esm": "^3.0.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vite-plugin-static-copy": "^4.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.48.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
